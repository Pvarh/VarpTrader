# Broker + Real-time data (Alpaca)
# Keys used for BOTH order execution AND the real-time WebSocket
# market-data feed (free IEX, 200 calls/min). No Polygon needed for live prices.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
PAPER_TRADE=true

# Crypto
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Historical data (Polygon REST — used ONLY for historical OHLCV / backtesting)
# If empty, yfinance is used as a free fallback. NOT used for live prices.
# Stock block-trade polling is disabled by default in config.json for low-tier Polygon plans.
POLYGON_API_KEY=
POLYGON_CALLS_PER_MINUTE=5
WHALE_ALERT_API_KEY=
NEWS_API_KEY=

# AI
# Nightly analysis / overseer / swing advisor can use Claude via VPS login mode.
ANTHROPIC_API_KEY=
VARPTRADER_CLAUDE_AUTH_MODE=login

# Signal quality controls
SIGNAL_RETRY_COOLDOWN_SECONDS=900
SIGNAL_RETRY_PRICE_TOLERANCE_PCT=0.005
LOSS_COOLDOWN_MINUTES=180
LOSS_COOLDOWN_STREAK=2

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard
DASHBOARD_API_KEY=

# Database
DB_PATH=./data/trades.db
LOG_PATH=./logs
